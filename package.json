{
  "name": "vue3-windows",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "Draggable, resizable, minimizable window components for Vue 3.",
  "packageManager": "bun@1.3.4",
  "main": "./dist/vue3-windows.umd.cjs",
  "module": "./dist/vue3-windows.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vue3-windows.js",
      "require": "./dist/vue3-windows.umd.cjs"
    },
    "./style.css": "./dist/vue3-windows.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vitepress dev docs --host 0.0.0.0",
    "build": "bun run build:lib && bun run build:docs",
    "build:lib": "bunx vue-tsc -b && bunx vite build",
    "build:docs": "bun run changelog && bunx vitepress build docs",
    "preview": "bunx vitepress preview docs --host 0.0.0.0",
    "changelog": "bun run scripts/generate-changelog.ts"
  },
  "keywords": [
    "vue",
    "vue3",
    "window",
    "desktop",
    "dialog",
    "component"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.34",
    "vue-tsc": "^3.1.5"
  }
}
