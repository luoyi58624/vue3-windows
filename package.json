{
  "name": "vue3-windows",
  "private": false,
  "version": "1.2.1",
  "type": "module",
  "description": "Lightweight hook-driven window manager for Vue 3.",
  "repository": {
    "type": "git",
    "url": "https://github.com/luoyi58624/vue3-windows"
  },
  "packageManager": "bun@1.3.4",
  "main": "./dist/vue3-windows.umd.cjs",
  "module": "./dist/vue3-windows.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vue3-windows.js",
      "require": "./dist/vue3-windows.umd.cjs"
    },
    "./style.css": "./dist/vue3-windows.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vitepress dev docs --host 0.0.0.0 --port 4000",
    "dev:local": "bunx vite --config examples/native/vite.config.ts",
    "build": "bun run build:lib && bun run build:docs",
    "build:lib": "bunx vue-tsc -b && bunx vite build",
    "build:local": "bunx vite build --config examples/native/vite.config.ts",
    "build:docs": "bunx vitepress build docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "bunx vitepress preview docs --host 0.0.0.0",
    "release": "bun run scripts/release.ts",
    "install:hooks": "bun run scripts/install-git-hooks.ts",
    "prepare": "bun run install:hooks"
  },
  "keywords": [
    "vue",
    "vue3",
    "window",
    "dialog",
    "component"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-tsc": "^3.1.5"
  }
}
